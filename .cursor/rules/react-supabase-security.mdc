### 14. DASTツールによる自動セキュリティスキャン

#### ProbelyなどのDASTツールの活用

```typescript
// DASTツールとの統合例
import { ProbelyAPI } from './probely-client'

export class SecurityScanner {
  private probely: ProbelyAPI

  constructor(apiKey: string) {
    this.probely = new ProbelyAPI(apiKey)
  }

  async scanApplication(targetUrl: string) {
    // スキャン開始
    const scanId = await this.probely.startScan({
      url: targetUrl,
      scan_type: 'full',
      technologies: ['react', 'nextjs', 'supabase'],
    })

    // スキャン完了まで待機
    await this.waitForScanCompletion(scanId)

    // 結果取得
    const results = await this.probely.getScanResults(scanId)

    // 脆弱性の分類と優先順位付け
    return this.prioritizeVulnerabilities(results)
  }

  private async waitForScanCompletion(scanId: string) {
    let status = 'running'
    while (status === 'running') {
      await new Promise(resolve => setTimeout(resolve, 30000)) // 30秒待機
      const scanStatus = await this.probely.getScanStatus(scanId)
      status = scanStatus.state
    }
  }

  private prioritizeVulnerabilities(results: any[]) {
    const severityOrder = { critical: 4, high: 3, medium: 2, low: 1, info: 0 }

    return results.sort((a, b) =>
      severityOrder[b.severity] - severityOrder[a.severity]
    )
  }
}
```

