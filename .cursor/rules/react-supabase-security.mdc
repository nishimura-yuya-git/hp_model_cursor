### 12. ワンタイムパスワード（OTP）のセキュリティ考慮事項

#### SMS/メールベースOTPの脆弱性

```typescript
// ❌ 危険：SMSベースの認証のみ
const sendOTP = async (phoneNumber: string) => {
  const otp = Math.floor(100000 + Math.random() * 900000)
  await sendSMS(phoneNumber, `Your OTP: ${otp}`)
  // 攻撃者がSIMスワップ攻撃でOTPを盗める
}
