```sql
-- RLSポリシーによるアクセス制御
CREATE POLICY "Users can view own data" ON users
  FOR SELECT USING (auth.uid() = user_id);

-- 関数ベースの安全なクエリ
CREATE OR REPLACE FUNCTION get_user_data(user_id_param UUID)
RETURNS TABLE(user_data JSON)
LANGUAGE plpgsql
SECURITY DEFINER
AS $$
BEGIN
  -- パラメータ化されたクエリ
  RETURN QUERY
  SELECT json_build_object(
    'id', id,
    'email', email,
    'name', name
  )
  FROM users
  WHERE id = user_id_param
  AND auth.uid() = user_id_param;  -- 追加のセキュリティチェック
END;
$$;
