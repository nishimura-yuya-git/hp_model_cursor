### 既存エンドポイントの仕様
エンドポイント: `POST /api/sendgrid/emails`

リクエスト（JSON）:
```json
{
  "from": "no-reply@example.com",
  "to": "user@example.com",
  "subject": "件名",
  "html": "<p>本文</p>",
  "text": "本文のプレーンテキスト版(任意)",
  "reply_to": "support@example.com"
}
```

レスポンス:
```json
// 成功
{ "success": true }

// 失敗
{ "error": "..." }
```

サーバー実装（抜粋・既存）:
```javascript
// api/sendgrid/emails.js
export default async function handler(req, res) {
  res.setHeader('Access-Control-Allow-Credentials', 'true');
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'OPTIONS, POST');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');

  if (req.method === 'OPTIONS') return res.status(200).end();
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const apiKey = process.env.SENDGRID_API_KEY;
  if (!apiKey) return res.status(500).json({ error: 'SENDGRID_API_KEY is not configured' });

  try {
    const { from, to, subject, html, text, reply_to } = req.body || {};
    if (!from || !to || !subject || (!html && !text)) {
      return res.status(400).json({ error: 'Missing required parameters' });
    }

    const companyName = process.env.VITE_COMPANY_NAME || 'SocialBoost';
    const fromHeader = from.includes('<') ? from : `${companyName} <${from}>`;

    const payload = {
      personalizations: [
        {
          to: Array.isArray(to) ? to.map((t) => ({ email: t })) : [{ email: to }],
          subject,
        },
      ],
      from: { email: fromHeader.match(/<(.+)>/)?.[1] || fromHeader, name: companyName },
      reply_to: { email: reply_to || fromHeader.match(/<(.+)>/)?.[1] || fromHeader },
      content: [ html ? { type: 'text/html', value: html } : { type: 'text/plain', value: text } ],
    };

    const sgRes = await fetch('https://api.sendgrid.com/v3/mail/send', {
      method: 'POST',
      headers: { Authorization: `Bearer ${apiKey}`, 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    if (!sgRes.ok) {
      const err = await sgRes.text();
      return res.status(sgRes.status).json({ error: err });
    }
    res.status(200).json({ success: true });
  } catch (e) {
    res.status(500).json({ error: e.message || 'Unknown error' });
  }
}
```

