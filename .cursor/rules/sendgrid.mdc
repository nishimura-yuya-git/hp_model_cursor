### フロントからの呼び出し例（TypeScript）
```ts
// src/utils/sendgrid.ts
export interface SendgridPayload {
  from: string;
  to: string | string[];
  subject: string;
  html?: string;
  text?: string;
  reply_to?: string;
}

export const sendMail = async (payload: SendgridPayload) => {
  const res = await fetch('/api/sendgrid/emails', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  });
  const data = await res.json();
  if (!res.ok) throw new Error(data?.error || 'メール送信に失敗しました');
  return data as { success: true };
};
```

使用例:
```ts
await sendMail({
  from: 'no-reply@example.com',
  to: 'user@example.com',
  subject: 'お問い合わせありがとうございます',
  html: '<p>受付しました。</p>',
  reply_to: 'support@example.com'
});
```

既存のフォームは `src/components/ContactForm.tsx` → `src/utils/resendApi.ts` の `sendContactEmail()` を呼び出す構造。上記の `VITE_EMAIL_PROVIDER=sendgrid` を設定すれば、そのまま SendGrid で送信される。

