## 🚀 2. Vercel Serverless Function

### api/resend/emails.js
```javascript
import fetch from 'node-fetch';

export default async (req, res) => {
  // CORS設定
  res.setHeader('Access-Control-Allow-Credentials', true);
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Access-Control-Allow-Methods', 'OPTIONS, POST');
  res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');

  // プリフライトリクエスト処理
  if (req.method === 'OPTIONS') {
    res.status(200).end();
    return;
  }

  // POSTメソッドのみ許可
  if (req.method !== 'POST') {
    res.status(405).json({ error: 'Method not allowed' });
    return;
  }

  // APIキー取得
  const apiKey = process.env.RESEND_API_KEY || process.env.VITE_RESEND_API_KEY;
  if (!apiKey) {
    console.error('Resend API Key not configured');
    return res.status(500).json({ error: 'API key not configured' });
  }

  try {
    const { from, to, subject, html, text, reply_to } = req.body;

    // 必須パラメータチェック
    if (!from || !to || !subject || (!html && !text)) {
      return res.status(400).json({ error: 'Missing required parameters' });
    }

    // 送信者名最適化
    let optimizedFrom = from;
    if (from.indexOf('<') === -1 && from.indexOf('@') !== -1) {
      const companyName = process.env.VITE_COMPANY_NAME || 'Your Company';
      optimizedFrom = `${companyName} <${from}>`;
    }

    // メールパラメータ
    const emailParams = {
      from: optimizedFrom,
      to,
      subject,
      reply_to: reply_to || from,
    };

    // HTML/テキスト設定
    if (html) emailParams.html = html;
    if (text) {
      emailParams.text = text;
    } else if (html) {
      // HTMLからプレーンテキスト自動生成
      emailParams.text = html
        .replace(/<br\s*\/?>/gi, '\n')
        .replace(/<p[^>]*>/gi, '\n')
        .replace(/<\/p>/gi, '\n')
        .replace(/<[^>]*>/g, '')
        .replace(/\n{3,}/g, '\n\n')
        .trim();
    }

    // Resend API呼び出し
    const resendResponse = await fetch('https://api.resend.com/emails', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`
      },
      body: JSON.stringify(emailParams)
    });

    const data = await resendResponse.json();

    if (!resendResponse.ok) {
      console.error('Resend API error:', data);
      return res.status(resendResponse.status).json(data);
    }

    console.log('Email sent successfully:', data);
    return res.status(200).json(data);
  } catch (error) {
    console.error('Email sending error:', error);
    return res.status(500).json({ 
      error: error.message 
    });
  }
};
```

## 🎯 3. フロントエンド API ユーティリティ

### src/utils/resendApi.ts
```typescript
// メール設定
const EMAIL_CONFIG = {
  SENDER: import.meta.env.VITE_EMAIL_SENDER || 'noreply@yourdomain.com',
  ADMIN: import.meta.env.VITE_ADMIN_EMAIL || 'admin@yourdomain.com',
  REPLY_TO: import.meta.env.VITE_REPLY_TO_EMAIL || 'support@yourdomain.com',
  COMPANY_NAME: import.meta.env.VITE_COMPANY_NAME || 'Your Company',
  COMPANY_URL: import.meta.env.VITE_COMPANY_URL || 'https://yourdomain.com',
};

/**
 * メール送信関数
 */
const sendEmail = async (params: {
  from: string;
  to: string;
  subject: string;
  html: string;
  text?: string;
  reply_to?: string;
}) => {
  try {
    // プレーンテキスト版がない場合、HTMLから生成
    if (!params.text && params.html) {
      params.text = params.html
        .replace(/<br\s*\/?>/gi, '\n')
        .replace(/<p[^>]*>/gi, '\n')
        .replace(/<\/p>/gi, '\n')
        .replace(/<[^>]*>/g, '')
        .replace(/\n{3,}/g, '\n\n')
        .trim();
    }

    // APIエンドポイント
    const apiEndpoint = `${window.location.origin}/api/resend/emails`;
    
    console.log('Sending email:', {
      to: params.to,
      subject: params.subject,
      hasHtml: !!params.html,
      hasText: !!params.text
    });
    
    // API呼び出し
    const response = await fetch(apiEndpoint, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(params)
    });

    const result = await response.json();

    if (!response.ok) {
      throw new Error(`Email sending failed: ${JSON.stringify(result)}`);
    }

    return result;
  } catch (error) {
    console.error('Email sending error:', error);
    throw error;
  }
};

