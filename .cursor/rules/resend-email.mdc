/**
 * カスタムメール送信（汎用）
 */
export const sendCustomEmail = async ({
  to,
  subject,
  html,
  text,
  replyTo
}: {
  to: string;
  subject: string;
  html: string;
  text?: string;
  replyTo?: string;
}) => {
  return await sendEmail({
    from: EMAIL_CONFIG.SENDER,
    to,
    subject,
    html,
    text,
    reply_to: replyTo || EMAIL_CONFIG.REPLY_TO
  });
};

